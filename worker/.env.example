# GHL Private Integration Tokens per location (JSON array) — free, just auth
GHL_LOCATIONS_JSON=[{"locationId":"LOC_ID_SCHAUMBURG","name":"Schaumburg","token":"pit-..."},{"locationId":"LOC_ID_LINCOLNSHIRE","name":"Lincolnshire","token":"pit-..."}]

# Scoring engine:
#   cli (default) — spawns `claude -p`; bills the Claude subscription logged in on
#                   this host (`claude login` once as the service user). No API key.
#   api           — Anthropic API billing; requires ANTHROPIC_API_KEY. System
#                   prompts are prompt-cached.
CLAUDE_MODE=cli
ANTHROPIC_API_KEY=
# Model defaults: haiku/sonnet aliases (cli) or full model ids (api). Override here if needed.
#CLASSIFIER_MODEL=
#EVALUATOR_MODEL=
CLI_TIMEOUT_MS=180000

WEBHOOK_SECRET=set-a-long-random-string-and-mirror-it-in-the-ghl-workflow-header
REVIEW_THRESHOLD=0.7
MIN_CALL_SEC=45
MIN_EVAL_SEC=180
MIN_N=5
PORT=3131
DB_PATH=./data/calls.db
