# GHL Private Integration Tokens per location (JSON array) — free, just auth
GHL_LOCATIONS_JSON=[{"locationId":"LOC_ID_SCHAUMBURG","name":"Schaumburg","token":"pit-..."},{"locationId":"LOC_ID_LINCOLNSHIRE","name":"Lincolnshire","token":"pit-..."}]

# Scoring engine:
#   cli (default) — spawns `claude -p`; bills the Claude subscription logged in on
#                   this host (`claude login` once as the service user). No API key.
#   api           — Anthropic API billing; requires ANTHROPIC_API_KEY. System
#                   prompts are prompt-cached.
CLAUDE_MODE=cli
ANTHROPIC_API_KEY=
# Model defaults: haiku/sonnet aliases (cli) or full model ids (api). Override here if needed.
#CLASSIFIER_MODEL=
#EVALUATOR_MODEL=
CLI_TIMEOUT_MS=180000

WEBHOOK_SECRET=set-a-long-random-string-and-mirror-it-in-the-ghl-workflow-header

# Bridge (Apps Script web app in the Alloy account — bridge/ in repo root):
# writes the Call Quality tab to both L10 sheets + emails coaching reports.
BRIDGE_URL=https://script.google.com/macros/s/DEPLOYMENT_ID/exec
BRIDGE_SECRET=same-value-as-the-BRIDGE_SECRET-script-property
# Report delivery: staff display name -> email; unknown staff falls back.
STAFF_EMAILS_JSON={"Full Name":"email@example.com"}
REPORT_FALLBACK_EMAIL=owner@example.com
REPORT_MAX_AGE_DAYS=3
REVIEW_THRESHOLD=0.7
MIN_CALL_SEC=45
MIN_EVAL_SEC=180

# Plaud SPS intake (arm #2): shared Drive drop folder; location resolved by
# device hint in filename -> SPS calendar cross-check -> staff scan.
PLAUD_FOLDER_ID=
SPS_CALENDARS_JSON={"Schaumburg":"jIyS0g6ru5gVnk1h1Ebv","Lincolnshire":"0OVdEgoMKDpqvN7gsoSy"}
PLAUD_DEVICE_HINTS_JSON={"SCH":"Schaumburg","LINC":"Lincolnshire"}
PLAUD_MATCH_WINDOW_H=3
MIN_N=5
PORT=3131
DB_PATH=./data/calls.db
